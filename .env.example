# Anthropic API Key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ElevenLabs API Key (for TTS voice)
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# BeehiiV (newsletter)
# API key: https://app.beehiiv.com/settings/integrations
# Publication ID: found in your BeehiiV publication URL
BEEHIIV_API_KEY=your_beehiiv_key_here
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx

# Stripe (for purchasing fly packs)
# Sign up at: https://dashboard.stripe.com
# 1. Create a Product (e.g. "50 Flies") with a one-time price in Stripe Dashboard
# 2. Copy the Price ID (starts with price_) into STRIPE_PRICE_ID
# 3. Add a webhook endpoint pointing to https://yourdomain.com/api/webhook
#    listening for: checkout.session.completed
# 4. Copy the webhook signing secret into STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Port (optional, defaults to 3000)
PORT=3000
